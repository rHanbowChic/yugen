{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:path:default",
    "fs:allow-app-read",
    "fs:allow-appdata-read",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$RESOURCE/**/*" },
        { "path": "$APPDATA/**/*" }
      ]
    }

  ]
}
