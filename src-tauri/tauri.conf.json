{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yugen",
  "version": "1.0.0",
  "identifier": "fyi.ect.yugen",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Yugen v1.0.0",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; media-src 'self' asset: http://127.0.0.1:10454; connect-src 'self' ipc://localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**/*",
          "$CACHE/**",
          "$CONFIG/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/music.json"
    ]
  }
}
